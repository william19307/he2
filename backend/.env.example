# =============================================
# 心理健康测评平台 · 后端环境变量模板
# 复制本文件为 .env 后按需填写，所有 REQUIRED 项必填
# =============================================

# ---- 数据库 (REQUIRED) ----------------------
# 生产环境示例: mysql://root:<password>@db:3306/mentalhealth
DATABASE_URL="mysql://root:password@localhost:3306/mentalhealth"

# ---- Redis (OPTIONAL) -----------------------
# 当前版本暂未实际使用 Redis，可留空；
# 若后续启用 Session/缓存，填写完整 URL
# REDIS_URL="redis://redis:6379"

# ---- JWT (REQUIRED) -------------------------
# 生产环境必须修改为高强度随机字符串（建议 64 位以上）
# 生成命令: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-me-to-a-random-string-at-least-64-chars"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_EXPIRES_IN="7d"

# ---- 服务器 (REQUIRED) ----------------------
PORT=3002
# 必须设为 production，关闭详细错误堆栈输出
NODE_ENV=production

# ---- Node.js 内存 (OPTIONAL) ----------------
# 容器内限制堆内存，防止 OOM；Dockerfile 中已通过 CMD 传入，
# 若直接 node 启动请手动加: NODE_OPTIONS=--max-old-space-size=256
# NODE_OPTIONS=--max-old-space-size=256

# ---- 豆包（火山方舟）AI 倾诉 (OPTIONAL) -----
# 若不需要 AI 倾诉功能可留空，相关接口会返回兜底提示
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-1-5-pro-32k-250115
